[
  {
    "name": "tapping Daily advances to the reminder step",
    "steps": [
      { "send": { "text": "/start", "userId": 1, "chatId": 100 }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "/add", "userId": 1, "chatId": 100 }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "Read 10 pages", "userId": 1, "chatId": 100 }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "freq:daily", "userId": 1, "chatId": 100, "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Frequency: *Daily*.\n\nStep 3 of 4 — pick a reminder time. The [No reminder] / [Set time] picker lands in E2T4."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "tapping Weekdays skips the days step and goes to reminder",
    "steps": [
      { "send": { "text": "/start", "userId": 2, "chatId": 200 }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "/add", "userId": 2, "chatId": 200 }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "Stretch", "userId": 2, "chatId": 200 }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "freq:weekdays", "userId": 2, "chatId": 200, "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Frequency: *Weekdays (Mon–Fri)*.\n\nStep 3 of 4 — pick a reminder time. The [No reminder] / [Set time] picker lands in E2T4."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "tapping Specific days advances to the days picker (E2T3)",
    "steps": [
      { "send": { "text": "/start", "userId": 3, "chatId": 300 }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "/add", "userId": 3, "chatId": 300 }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "Yoga", "userId": 3, "chatId": 300 }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "freq:specific_days", "userId": 3, "chatId": 300, "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Frequency: *Specific days*.\n\nStep 3 of 4 — pick the weekdays. The Mon..Sun toggle lands in E2T3."
            }
          }
        ]
      }
    ]
  }
]

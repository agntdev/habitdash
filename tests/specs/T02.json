[
  {
    "name": "menu:add tap (from a feature card) edits to the Add habit card and Back restores the dashboard",
    "steps": [
      { "send": { "text": "/start", "userId": 1, "chatId": 100 }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "menu:add", "userId": 1, "chatId": 100, "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "➕ *Add habit*\n\nCreate a new habit to track. You'll set a name, a frequency (daily, weekdays, or specific days), and an optional reminder time.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "« Back to dashboard", "callback_data": "menu:back" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "menu:back", "userId": 1, "chatId": 100, "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "📊 *Your habits*\n\n🌱 _No habits yet — tap ➕ below to add your first one._"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "menu:list tap edits to the My habits card",
    "steps": [
      { "send": { "text": "/start", "userId": 1, "chatId": 100 }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "menu:list", "userId": 1, "chatId": 100, "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "« Back to dashboard", "callback_data": "menu:back" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "menu:stats tap edits to the Stats card",
    "steps": [
      { "send": { "text": "/start", "userId": 1, "chatId": 100 }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "menu:stats", "userId": 1, "chatId": 100, "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      }
    ]
  },
  {
    "name": "menu:help tap edits to the Help card",
    "steps": [
      { "send": { "text": "/start", "userId": 1, "chatId": 100 }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "menu:help", "userId": 1, "chatId": 100, "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      }
    ]
  }
]

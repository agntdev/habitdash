[
  {
    "name": "tapping ✓ Done refreshes the dashboard with streak: 1",
    "steps": [
      { "send": { "text": "/start", "userId": 1, "chatId": 100 }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "__seed_habit: Drink water", "userId": 1, "chatId": 100 }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "/start", "userId": 1, "chatId": 100 }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "callback": "done:1", "userId": 1, "chatId": 100, "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "📊 *Your habits*\n\n1. *Drink water* — streak: 1"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "after /list the streak count reflects today's completion",
    "steps": [
      { "send": { "text": "/start", "userId": 2, "chatId": 200 }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "__seed_habit: Meditate", "userId": 2, "chatId": 200 }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "/check", "userId": 2, "chatId": 200 }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "text": "/list", "userId": 2, "chatId": 200 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📊 *Your habits*\n\n1. *Meditate* — streak: 1"
            }
          }
        ]
      }
    ]
  }
]
